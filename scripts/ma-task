#!/usr/bin/env bash
set -euo pipefail

# ma-task: CLI tool for AI agents to manage my-agents tasks
# Reads/writes task.json files under ~/.my-agents/projects/

DATA_DIR="${MY_AGENTS_DATA_DIR:-${HOME}/.my-agents}"
PROJECTS_DIR="${DATA_DIR}/projects"

# ── Helpers ──────────────────────────────────────────────

die() { echo "error: $*" >&2; exit 1; }

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not found"
}

# Ensure jq is available
need_cmd jq

now_iso() {
    date -u +"%Y-%m-%dT%H:%M:%SZ"
}

gen_id() {
    # Generate 8-char hex ID (similar to UUID v4 prefix)
    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen | tr '[:upper:]' '[:lower:]' | cut -c1-8
    else
        head -c 4 /dev/urandom | od -A n -t x1 | tr -d ' \n' | cut -c1-8
    fi
}

validate_id() {
    local id="$1" label="$2"
    if [[ "$id" == *"/"* ]] || [[ "$id" == *"\\"* ]] || [[ "$id" == *".."* ]] || [[ -z "$id" ]]; then
        die "invalid ${label}: ${id}"
    fi
}

task_json_path() {
    local project_id="$1" task_id="$2"
    validate_id "$project_id" "project_id"
    validate_id "$task_id" "task_id"
    echo "${PROJECTS_DIR}/${project_id}/tasks/${task_id}/task.json"
}

read_task() {
    local path
    path="$(task_json_path "$1" "$2")"
    [ -f "$path" ] || die "task not found: $1/$2"
    cat "$path"
}

write_task() {
    local project_id="$1" task_id="$2" json="$3"
    local path
    path="$(task_json_path "$project_id" "$task_id")"
    mkdir -p "$(dirname "$path")"
    echo "$json" | jq . > "$path"
}

# Find task by ID across all projects (using first 6+ char prefix match)
find_task() {
    local search_id="$1"
    local found_project="" found_task=""
    for project_dir in "${PROJECTS_DIR}"/*/; do
        [ -d "$project_dir" ] || continue
        local pid
        pid="$(basename "$project_dir")"
        local tasks_dir="${project_dir}tasks"
        [ -d "$tasks_dir" ] || continue
        for task_dir in "${tasks_dir}"/*/; do
            [ -d "$task_dir" ] || continue
            local tid
            tid="$(basename "$task_dir")"
            if [ "$tid" = "$search_id" ] || [[ "$tid" == "${search_id}"* ]]; then
                if [ -n "$found_task" ]; then
                    die "ambiguous task ID '${search_id}': matches multiple tasks"
                fi
                found_project="$pid"
                found_task="$tid"
            fi
        done
    done
    [ -n "$found_task" ] || die "task not found: ${search_id}"
    echo "${found_project}/${found_task}"
}

# ── Detect current context from CWD ─────────────────────

detect_context() {
    local cwd
    cwd="$(pwd)"
    if [[ "$cwd" =~ \.my-agents/projects/([^/]+)/tasks/([^/]+) ]]; then
        echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
    else
        return 1
    fi
}

# ── Commands ─────────────────────────────────────────────

cmd_current() {
    local ctx
    ctx="$(detect_context)" || die "not inside a my-agents task directory"
    local project_id task_id
    project_id="${ctx%%/*}"
    task_id="${ctx#*/}"
    local json
    json="$(read_task "$project_id" "$task_id")"
    echo "$json"
}

cmd_get() {
    local task_id="${1:?usage: ma-task get <task-id>}"
    # Try detect project from context first
    local project_id=""
    if ctx="$(detect_context 2>/dev/null)"; then
        project_id="${ctx%%/*}"
        local path
        path="$(task_json_path "$project_id" "$task_id")"
        if [ -f "$path" ]; then
            cat "$path"
            return
        fi
    fi
    # Search across all projects
    local found
    found="$(find_task "$task_id")"
    project_id="${found%%/*}"
    task_id="${found#*/}"
    read_task "$project_id" "$task_id"
}

cmd_list() {
    local project_id=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --project|-p) project_id="${2:?--project requires value}"; shift 2 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    # Auto-detect project if not specified
    if [ -z "$project_id" ]; then
        if ctx="$(detect_context 2>/dev/null)"; then
            project_id="${ctx%%/*}"
        else
            die "specify --project or run from inside a task directory"
        fi
    fi

    local tasks_dir="${PROJECTS_DIR}/${project_id}/tasks"
    [ -d "$tasks_dir" ] || die "project not found: ${project_id}"

    local first=true
    echo "["
    for task_dir in "${tasks_dir}"/*/; do
        [ -d "$task_dir" ] || continue
        local task_file="${task_dir}task.json"
        [ -f "$task_file" ] || continue
        if [ "$first" = true ]; then
            first=false
        else
            echo ","
        fi
        cat "$task_file"
    done
    echo "]"
}

cmd_create() {
    local project_id="" name="" priority="P3" agent_cli="Claude" notes="" prompt="" run=false
    local -a links=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --project|-p) project_id="${2:?--project requires value}"; shift 2 ;;
            --name|-n) name="${2:?--name requires value}"; shift 2 ;;
            --priority) priority="${2:?--priority requires value}"; shift 2 ;;
            --agent) agent_cli="${2:?--agent requires value}"; shift 2 ;;
            --notes) notes="${2:?--notes requires value}"; shift 2 ;;
            --prompt) prompt="${2:?--prompt requires value}"; shift 2 ;;
            --link) links+=("${2:?--link requires value}"); shift 2 ;;
            --run) run=true; shift ;;
            *) die "unknown option: $1" ;;
        esac
    done

    [ -n "$project_id" ] || {
        if ctx="$(detect_context 2>/dev/null)"; then
            project_id="${ctx%%/*}"
        else
            die "--project is required"
        fi
    }
    [ -n "$name" ] || die "--name is required"

    # Validate project exists
    [ -d "${PROJECTS_DIR}/${project_id}" ] || die "project not found: ${project_id}"

    # Validate priority
    case "$priority" in
        P1|P2|P3|P4|P5) ;;
        *) die "invalid priority: ${priority} (use P1-P5)" ;;
    esac

    # Validate agent_cli
    case "$agent_cli" in
        Claude|claude) agent_cli="Claude" ;;
        Codex|codex) agent_cli="Codex" ;;
        Gemini|gemini) agent_cli="Gemini" ;;
        None|none) agent_cli="None" ;;
        *) die "invalid agent: ${agent_cli} (use Claude, Codex, Gemini, or None)" ;;
    esac

    local task_id now
    task_id="$(gen_id)"
    now="$(now_iso)"

    # Ensure unique ID
    while [ -d "${PROJECTS_DIR}/${project_id}/tasks/${task_id}" ]; do
        task_id="$(gen_id)"
    done

    local notes_json="null"
    [ -z "$notes" ] || notes_json="$(echo "$notes" | jq -Rs .)"

    local prompt_json="null"
    [ -z "$prompt" ] || prompt_json="$(echo "$prompt" | jq -Rs .)"

    # Build links JSON array
    local links_json="[]"
    if [ ${#links[@]} -gt 0 ]; then
        links_json="$(printf '%s\n' "${links[@]}" | jq -R '{"url": ., "display_name": null}' | jq -s .)"
    fi

    local json
    json="$(jq -n \
        --arg id "$task_id" \
        --arg pid "$project_id" \
        --arg name "$name" \
        --arg priority "$priority" \
        --arg agent "$agent_cli" \
        --argjson notes "$notes_json" \
        --argjson prompt "$prompt_json" \
        --argjson links "$links_json" \
        --arg now "$now" \
        '{
            id: $id,
            project_id: $pid,
            name: $name,
            priority: $priority,
            status: "Todo",
            agent_cli: $agent,
            worktrees: [],
            links: $links,
            preview_urls: [],
            notes: $notes,
            initial_instructions: $prompt,
            tmux_session: null,
            created_at: $now,
            updated_at: $now
        }')"

    write_task "$project_id" "$task_id" "$json"
    echo "$json"

    if [ "$run" = true ]; then
        # initial_instructions is required for run
        if [ -z "$prompt" ]; then
            die "--prompt is required when using --run. Provide initial instructions for the agent."
        fi
        local bin_path=""
        if [ -n "${MY_AGENTS_BIN:-}" ] && [ -x "${MY_AGENTS_BIN}" ]; then
            bin_path="${MY_AGENTS_BIN}"
        elif command -v my-agents >/dev/null 2>&1; then
            bin_path="my-agents"
        else
            die "my-agents binary not found in PATH; install with 'cargo install --path .' or set MY_AGENTS_BIN"
        fi
        exec "$bin_path" setup-task --project "$project_id" --task "$task_id"
    fi
}

cmd_update() {
    local task_id="${1:?usage: ma-task update <task-id> [--name ...] [--priority ...] [--notes ...] [--prompt ...] [--agent ...]}"; shift

    # Resolve task
    local project_id=""
    if ctx="$(detect_context 2>/dev/null)"; then
        project_id="${ctx%%/*}"
        if [ ! -f "$(task_json_path "$project_id" "$task_id")" ]; then
            local found
            found="$(find_task "$task_id")"
            project_id="${found%%/*}"
            task_id="${found#*/}"
        fi
    else
        local found
        found="$(find_task "$task_id")"
        project_id="${found%%/*}"
        task_id="${found#*/}"
    fi

    local json
    json="$(read_task "$project_id" "$task_id")"

    while [ $# -gt 0 ]; do
        case "$1" in
            --name|-n)
                json="$(echo "$json" | jq --arg v "$2" '.name = $v')"
                shift 2 ;;
            --priority)
                case "$2" in
                    P1|P2|P3|P4|P5) ;;
                    *) die "invalid priority: $2" ;;
                esac
                json="$(echo "$json" | jq --arg v "$2" '.priority = $v')"
                shift 2 ;;
            --notes)
                json="$(echo "$json" | jq --arg v "$2" '.notes = $v')"
                shift 2 ;;
            --agent)
                local agent_val="$2"
                case "$agent_val" in
                    Claude|claude) agent_val="Claude" ;;
                    Codex|codex) agent_val="Codex" ;;
                    None|none) agent_val="None" ;;
                    *) die "invalid agent: $agent_val (use Claude, Codex, or None)" ;;
                esac
                json="$(echo "$json" | jq --arg v "$agent_val" '.agent_cli = $v')"
                shift 2 ;;
            --prompt)
                json="$(echo "$json" | jq --arg v "$2" '.initial_instructions = $v')"
                shift 2 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    json="$(echo "$json" | jq --arg now "$(now_iso)" '.updated_at = $now')"
    write_task "$project_id" "$task_id" "$json"
    echo "$json"
}

cmd_status() {
    local task_id="${1:?usage: ma-task status <task-id> <status>}"
    local new_status="${2:?usage: ma-task status <task-id> <status>}"

    # Validate status
    case "$new_status" in
        Todo|InProgress|ActionRequired|Completed|Blocked) ;;
        todo) new_status="Todo" ;;
        inprogress|in-progress|in_progress) new_status="InProgress" ;;
        actionrequired|action-required|action_required) new_status="ActionRequired" ;;
        completed|done) new_status="Completed" ;;
        blocked) new_status="Blocked" ;;
        *) die "invalid status: ${new_status} (use Todo, InProgress, ActionRequired, Completed, Blocked)" ;;
    esac

    # Resolve task
    local project_id=""
    if ctx="$(detect_context 2>/dev/null)"; then
        project_id="${ctx%%/*}"
        if [ ! -f "$(task_json_path "$project_id" "$task_id")" ]; then
            local found
            found="$(find_task "$task_id")"
            project_id="${found%%/*}"
            task_id="${found#*/}"
        fi
    else
        local found
        found="$(find_task "$task_id")"
        project_id="${found%%/*}"
        task_id="${found#*/}"
    fi

    local json
    json="$(read_task "$project_id" "$task_id")"

    # Skip write if status is already the same
    local current_status
    current_status="$(echo "$json" | jq -r '.status')"
    if [ "$current_status" = "$new_status" ]; then
        echo "$json"
        return 0
    fi

    json="$(echo "$json" | jq --arg s "$new_status" --arg now "$(now_iso)" '.status = $s | .updated_at = $now')"
    write_task "$project_id" "$task_id" "$json"
    echo "$json"
}

cmd_link() {
    local task_id="${1:?usage: ma-task link <task-id> <url> [--name <display-name>]}"
    local url="${2:?usage: ma-task link <task-id> <url> [--name <display-name>]}"
    shift 2

    local display_name=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --name|-n) display_name="${2:?--name requires value}"; shift 2 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    # Resolve task
    local project_id=""
    if ctx="$(detect_context 2>/dev/null)"; then
        project_id="${ctx%%/*}"
        if [ ! -f "$(task_json_path "$project_id" "$task_id")" ]; then
            local found
            found="$(find_task "$task_id")"
            project_id="${found%%/*}"
            task_id="${found#*/}"
        fi
    else
        local found
        found="$(find_task "$task_id")"
        project_id="${found%%/*}"
        task_id="${found#*/}"
    fi

    local json
    json="$(read_task "$project_id" "$task_id")"
    # Skip if the same URL already exists
    if echo "$json" | jq -e --arg url "$url" '.links | any(.url == $url)' >/dev/null 2>&1; then
        echo "$json"
        return 0
    fi
    if [ -n "$display_name" ]; then
        json="$(echo "$json" | jq --arg url "$url" --arg dn "$display_name" \
            --arg now "$(now_iso)" \
            '.links += [{"url": $url, "display_name": $dn}] | .updated_at = $now')"
    else
        json="$(echo "$json" | jq --arg url "$url" \
            --arg now "$(now_iso)" \
            '.links += [{"url": $url, "display_name": null}] | .updated_at = $now')"
    fi
    write_task "$project_id" "$task_id" "$json"
    echo "$json"
}

cmd_preview_url() {
    local task_id="${1:?usage: ma-task preview-url <task-id> <url> --name <service-name>}"
    local url="${2:?usage: ma-task preview-url <task-id> <url> --name <service-name>}"
    shift 2

    local service_name=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --name|-n) service_name="${2:?--name requires value}"; shift 2 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    [ -n "$service_name" ] || die "--name <service-name> is required"

    # Resolve task
    local project_id=""
    if ctx="$(detect_context 2>/dev/null)"; then
        project_id="${ctx%%/*}"
        if [ ! -f "$(task_json_path "$project_id" "$task_id")" ]; then
            local found
            found="$(find_task "$task_id")"
            project_id="${found%%/*}"
            task_id="${found#*/}"
        fi
    else
        local found
        found="$(find_task "$task_id")"
        project_id="${found%%/*}"
        task_id="${found#*/}"
    fi

    local json
    json="$(read_task "$project_id" "$task_id")"

    # Ensure preview_urls field exists
    json="$(echo "$json" | jq 'if .preview_urls == null then .preview_urls = [] else . end')"

    # Upsert: update existing entry with same service_name, or add new
    json="$(echo "$json" | jq --arg sn "$service_name" --arg url "$url" \
        --arg now "$(now_iso)" \
        'if (.preview_urls | any(.service_name == $sn))
         then .preview_urls = [.preview_urls[] | if .service_name == $sn then .url = $url else . end]
         else .preview_urls += [{"service_name": $sn, "url": $url}]
         end | .updated_at = $now')"

    write_task "$project_id" "$task_id" "$json"
    echo "$json"
}

cmd_projects() {
    local first=true
    echo "["
    for project_dir in "${PROJECTS_DIR}"/*/; do
        [ -d "$project_dir" ] || continue
        local project_file="${project_dir}project.json"
        [ -f "$project_file" ] || continue
        if [ "$first" = true ]; then
            first=false
        else
            echo ","
        fi
        jq '{id: .id, name: .name, description: .description}' "$project_file"
    done
    echo "]"
}

cmd_run() {
    local task_id="${1:?usage: ma-task run <task-id>}"
    shift

    # Resolve task
    local project_id=""
    if ctx="$(detect_context 2>/dev/null)"; then
        project_id="${ctx%%/*}"
        if [ ! -f "$(task_json_path "$project_id" "$task_id")" ]; then
            local found
            found="$(find_task "$task_id")"
            project_id="${found%%/*}"
            task_id="${found#*/}"
        fi
    else
        local found
        found="$(find_task "$task_id")"
        project_id="${found%%/*}"
        task_id="${found#*/}"
    fi

    local json
    json="$(read_task "$project_id" "$task_id")"

    # Warn if agent_cli is None
    local agent_cli
    agent_cli="$(echo "$json" | jq -r '.agent_cli')"
    if [ "$agent_cli" = "None" ]; then
        die "No agent CLI configured for task '${task_id}'. Use 'ma-task update ${task_id} --agent Claude' to set one before running."
    fi

    # initial_instructions is required for run
    local initial_instructions
    initial_instructions="$(echo "$json" | jq -r '.initial_instructions // empty')"
    if [ -z "$initial_instructions" ]; then
        die "initial_instructions is required to run a task. Use 'ma-task update ${task_id} --prompt <text>' to set initial instructions before running."
    fi

    # If task already has worktrees or tmux session, report current state and exit
    local has_worktrees has_session
    has_worktrees="$(echo "$json" | jq '.worktrees | length')"
    has_session="$(echo "$json" | jq -r '.tmux_session // empty')"

    if [ "$has_worktrees" -gt 0 ] || [ -n "$has_session" ]; then
        # Session/worktrees exist but agent may not be running.
        # Launch agent with initial instructions in the existing session.
        local bin_path=""
        if [ -n "${MY_AGENTS_BIN:-}" ] && [ -x "${MY_AGENTS_BIN}" ]; then
            bin_path="${MY_AGENTS_BIN}"
        elif command -v my-agents >/dev/null 2>&1; then
            bin_path="my-agents"
        else
            die "my-agents binary not found in PATH; install with 'cargo install --path .' or set MY_AGENTS_BIN"
        fi
        exec "$bin_path" launch-agent --project "$project_id" --task "$task_id"
    fi

    # Delegate to my-agents setup-task for fresh tasks
    local bin_path=""
    if [ -n "${MY_AGENTS_BIN:-}" ] && [ -x "${MY_AGENTS_BIN}" ]; then
        bin_path="${MY_AGENTS_BIN}"
    elif command -v my-agents >/dev/null 2>&1; then
        bin_path="my-agents"
    else
        die "my-agents binary not found in PATH; install with 'cargo install --path .' or set MY_AGENTS_BIN"
    fi
    exec "$bin_path" setup-task --project "$project_id" --task "$task_id"
}

cmd_delete() {
    local task_id="${1:?usage: ma-task delete <task-id>}"; shift
    while [ $# -gt 0 ]; do
        case "$1" in
            --force|-f) shift ;;  # accepted for backward compat, but no-op
            *) die "unknown option: $1" ;;
        esac
    done

    # Resolve task
    local project_id=""
    if ctx="$(detect_context 2>/dev/null)"; then
        project_id="${ctx%%/*}"
        if [ ! -f "$(task_json_path "$project_id" "$task_id")" ]; then
            local found
            found="$(find_task "$task_id")"
            project_id="${found%%/*}"
            task_id="${found#*/}"
        fi
    else
        local found
        found="$(find_task "$task_id")"
        project_id="${found%%/*}"
        task_id="${found#*/}"
    fi

    local json
    json="$(read_task "$project_id" "$task_id")"

    local -a warnings=()

    # Kill tmux session (validate prefix to prevent killing unrelated sessions)
    local tmux_session
    tmux_session="$(echo "$json" | jq -r '.tmux_session // empty')"
    if [ -n "$tmux_session" ]; then
        if [[ "$tmux_session" == ma-* ]]; then
            if ! tmux kill-session -t "$tmux_session" 2>/dev/null; then
                warnings+=("tmux session '${tmux_session}' could not be killed (may not exist)")
            fi
        else
            warnings+=("skipped killing tmux session '${tmux_session}': unexpected name prefix")
        fi
    fi

    # Remove worktrees
    local worktree_count
    worktree_count="$(echo "$json" | jq '.worktrees | length')"
    for ((i=0; i<worktree_count; i++)); do
        local wt_path upstream_path branch
        wt_path="$(echo "$json" | jq -r ".worktrees[$i].worktree_path")"
        upstream_path="$(echo "$json" | jq -r ".worktrees[$i].upstream_path")"
        branch="$(echo "$json" | jq -r ".worktrees[$i].branch")"

        # Validate branch name prefix
        if [[ "$branch" != task/* ]]; then
            warnings+=("skipped branch deletion for '${branch}': unexpected prefix")
            continue
        fi

        if [ -n "$upstream_path" ] && [ -d "$upstream_path" ]; then
            if ! git -C "$upstream_path" worktree remove "$wt_path" --force 2>/dev/null; then
                git -C "$upstream_path" worktree prune 2>/dev/null || true
                warnings+=("worktree '${wt_path}' force-pruned (graceful remove failed)")
            fi
            # Delete branch (best-effort)
            git -C "$upstream_path" branch -D "$branch" 2>/dev/null || true
        else
            warnings+=("upstream repo '${upstream_path}' not found, skipped worktree cleanup")
        fi
    done

    # Remove ~/.claude.json trust entries (best-effort, mirrors Rust cleanup_task)
    local claude_json="${HOME}/.claude.json"
    if [ -f "$claude_json" ] && command -v jq >/dev/null 2>&1; then
        local task_dir="${PROJECTS_DIR}/${project_id}/tasks/${task_id}"
        local updated
        if updated="$(jq --arg prefix "$task_dir" '
            if .trustedDirectories then
                .trustedDirectories |= with_entries(select(.key | startswith($prefix) | not))
            else . end
        ' "$claude_json" 2>/dev/null)"; then
            echo "$updated" > "$claude_json" 2>/dev/null || \
                warnings+=("failed to update ~/.claude.json trust entries")
        fi
    fi

    # Delete task directory
    local task_dir="${PROJECTS_DIR}/${project_id}/tasks/${task_id}"
    if [ -d "$task_dir" ]; then
        if ! rm -rf "$task_dir"; then
            warnings+=("failed to remove task directory '${task_dir}'")
        fi
    fi

    # Build result JSON with jq for proper escaping
    local warnings_json="[]"
    if [ ${#warnings[@]} -gt 0 ]; then
        warnings_json="$(printf '%s\n' "${warnings[@]}" | jq -R . | jq -s .)"
    fi
    jq -n \
        --argjson deleted true \
        --arg task_id "$task_id" \
        --arg project_id "$project_id" \
        --argjson warnings "$warnings_json" \
        '{deleted: $deleted, task_id: $task_id, project_id: $project_id, warnings: $warnings}'

    # Exit non-zero if there were critical warnings (worktree/dir removal failures)
    if [ ${#warnings[@]} -gt 0 ]; then
        for w in "${warnings[@]}"; do
            echo "warning: $w" >&2
        done
        return 1
    fi
}

cmd_help() {
    cat <<'HELP'
ma-task: Task management CLI for my-agents

Usage: ma-task <command> [options]

Commands:
  current                          Show current task (auto-detected from CWD)
  get <task-id>                    Get task details (JSON)
  list [--project <id>]            List tasks in project (JSON array)
  projects                         List all projects (JSON array)
  create --name <n> [options]      Create a new task
  update <task-id> [options]       Update task fields
  status <task-id> <status>        Change task status
  link <task-id> <url> [--name n]  Add a link to task
  preview-url <id> <url> --name n Register a preview URL for task
  run <task-id>                    Set up worktree, tmux, and launch agent for existing task
  delete <task-id>                 Delete task and clean up resources
  help                             Show this help

Create options:
  --project, -p <id>    Project ID (auto-detected if in task dir)
  --name, -n <name>     Task name (required)
  --priority <P1-P5>    Priority (default: P3)
  --agent <cli>         Agent CLI: Claude, Codex, Gemini, None (default: Claude)
  --notes <text>        Initial notes
  --prompt <text>       Initial instructions for the agent (required for --run)
  --link <url>          Add a link (repeatable for multiple links)
  --run                 Set up worktree, tmux session, and launch agent immediately (requires --prompt)

Update options:
  --name, -n <name>     New task name
  --priority <P1-P5>    New priority
  --notes <text>        New notes
  --prompt <text>       Update initial instructions
  --agent <cli>         Agent CLI: Claude, Codex, Gemini, None

Status values:
  Todo, InProgress, ActionRequired, Completed, Blocked
HELP
}

# ── Main ─────────────────────────────────────────────────

cmd="${1:-help}"
shift || true

case "$cmd" in
    current)  cmd_current "$@" ;;
    get)      cmd_get "$@" ;;
    list)     cmd_list "$@" ;;
    projects) cmd_projects "$@" ;;
    create)   cmd_create "$@" ;;
    update)   cmd_update "$@" ;;
    status)   cmd_status "$@" ;;
    link)        cmd_link "$@" ;;
    preview-url) cmd_preview_url "$@" ;;
    run)         cmd_run "$@" ;;
    delete)   cmd_delete "$@" ;;
    help|--help|-h) cmd_help ;;
    *) die "unknown command: $cmd (run 'ma-task help')" ;;
esac
